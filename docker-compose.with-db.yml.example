# Configuration with internal database
services:
  beshence_bank:
    build: .
    image: beshence_bank:latest
    extra_hosts:
      - "host.docker.internal:host-gateway"
    environment:
      DATABASE_URL: "postgres://bank:bank@postgres:5432/bank?sslmode=disable"
      JWT_SECRET: ${JWT_SECRET:-local_dev_secret_change_me}
      JWT_TTL_SECONDS: ${JWT_TTL_SECONDS:-3600}
    ports:
      - "${HOST_PORT:-27462}:27462"
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:27462/api/ping || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10
    depends_on:
      postgres:
        condition: service_healthy
  postgres:
    image: postgres:17-alpine
    environment:
      POSTGRES_DB: bank
      POSTGRES_USER: bank
      POSTGRES_PASSWORD: bank
    volumes:
      - postgres_data:/var/lib/postgresql/data
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U bank -d bank"]
      interval: 10s
      timeout: 5s
      retries: 10

volumes:
  postgres_data:

